# ============================================================
# .env.example — Memory MCP Server
# ============================================================
# Скопируй в .env и заполни реальными значениями
# .env уже в .gitignore — не закоммить случайно
# ============================================================

# --- PostgreSQL (локальный, через профиль local-db) ---
DATABASE_URL=postgresql+asyncpg://athena_app:${APP_PASSWORD}@postgres:5432/athena_memory
PG_USER=athena
PG_PASSWORD=              # Обязательно: сгенерировать! python3 -c "import secrets; print(secrets.token_urlsafe(32))"
PG_DATABASE=athena_memory
APP_PASSWORD=             # Обязательно: отдельный пароль для athena_app

# --- Redis (локальный, через профиль local-db) ---
REDIS_PASSWORD=           # Обязательно: сгенерировать!

# --- Эмбеддинги ---
EMBEDDING_API_URL=http://10.0.0.21:8080/v1
EMBEDDING_API_KEY=
EMBEDDING_MODEL=qwen3-embedding-8b
EMBEDDING_DIMENSION=8192

# --- MCP Server ---
MCP_SERVER_NAME=athena-memory
MCP_HOST=0.0.0.0
MCP_PORT=8000
SEARCH_DEFAULT_LIMIT=10
SEARCH_DEFAULT_THRESHOLD=0.7
LOG_LEVEL=INFO
